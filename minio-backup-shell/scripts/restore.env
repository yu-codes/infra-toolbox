# ============================================================
# MinIO 還原環境變數設定
# ============================================================
# 注意：此檔案為選用，主要設定會從 backup.env 載入
# 這裡的設定會覆蓋 backup.env 中的對應設定

# ---------- 還原目標 MinIO 設定（選用） ----------
# 如果要還原到不同的 MinIO 實例，可以在這裡設定
# 否則將使用 backup.env 中的設定

# 範例：還原到新的 MinIO 實例
# RESTORE_MINIO_HOST=http://192.168.1.100:9000
# RESTORE_MINIO_USER=NEW_MINIO_USER
# RESTORE_MINIO_PASS=NEW_MINIO_PASSWORD
# RESTORE_MINIO_ALIAS=restore_target

# ---------- 還原選項 ----------
# 預設還原模式（可被命令列參數覆蓋）
# DEFAULT_RESTORE_TYPE=full          # full/incremental/offsite
# DEFAULT_TARGET_ALIAS=dbminio       # 預設還原到原 MinIO

# 是否在還原前自動備份目標
# AUTO_BACKUP_BEFORE_RESTORE=false

# 還原完成後是否驗證資料完整性
# VERIFY_AFTER_RESTORE=false

# ---------- 安全選項 ----------
# 是否需要確認才能執行還原（建議保持開啟）
# REQUIRE_CONFIRMATION=true

# 是否允許覆蓋現有資料
# ALLOW_OVERWRITE=true

# ---------- 還原日誌 ----------
# 還原操作的日誌檔案（預設使用備份日誌）
# RESTORE_LOG_FILE=$BACKUP_BASE/logs/minio-restore.log
