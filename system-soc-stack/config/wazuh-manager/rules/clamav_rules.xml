<!--
  ClamAV Custom Rules for Wazuh
  System SOC Stack
  
  Rule ID Range: 100100 - 100199 (custom ClamAV rules)
  
  Alert Levels:
    3  = Low (scan events, informational)
    7  = Medium (scan errors, suspicious activity)
    12 = High (malware detected)
    14 = Critical (multiple infections, active threat)
-->
<group name="clamav,antivirus,">

  <!-- ======================================================================
       BASE RULE: Match ClamAV log events from file monitor
       ====================================================================== -->

  <!-- Base rule: ClamAV scan log event -->
  <rule id="100100" level="0">
    <location>/var/log/clamav</location>
    <match>clamav</match>
    <description>ClamAV event detected.</description>
  </rule>

  <!-- ======================================================================
       MALWARE DETECTION RULES
       ====================================================================== -->

  <!-- HIGH: Malware detected by ClamAV -->
  <rule id="100101" level="12">
    <if_sid>100100</if_sid>
    <regex>FOUND|MALWARE_DETECTED</regex>
    <description>ClamAV: Malware detected</description>
    <options>alert_by_email</options>
    <group>virus_detected,malware,pci_dss_5.1,pci_dss_5.2,gpg13_4.2,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.3,tsc_CC6.8,</group>
  </rule>

  <!-- CRITICAL: Multiple malware detections in short time (frequency rule) -->
  <rule id="100102" level="14" frequency="3" timeframe="300">
    <if_matched_sid>100101</if_matched_sid>
    <description>ClamAV: Multiple malware detections - possible active infection or outbreak</description>
    <options>alert_by_email</options>
    <group>virus_detected,malware,attack,pci_dss_5.1,pci_dss_5.2,pci_dss_11.4,</group>
  </rule>

  <!-- HIGH: Known dangerous malware families -->
  <rule id="100103" level="13">
    <if_sid>100101</if_sid>
    <regex>Trojan|Ransomware|Backdoor|Rootkit|Exploit</regex>
    <description>ClamAV: High-risk malware detected</description>
    <options>alert_by_email</options>
    <group>virus_detected,malware,high_risk,pci_dss_5.1,pci_dss_5.2,pci_dss_11.4,</group>
  </rule>

  <!-- ======================================================================
       SCAN STATUS RULES
       ====================================================================== -->

  <!-- LOW: Scan completed clean -->
  <rule id="100110" level="3">
    <if_sid>100100</if_sid>
    <regex>SCAN_COMPLETED\.+CLEAN|Infected files: 0</regex>
    <description>ClamAV: Scheduled scan completed - no threats found</description>
    <group>clamav_scan,</group>
  </rule>

  <!-- MEDIUM: Scan completed with infections -->
  <rule id="100111" level="7">
    <if_sid>100100</if_sid>
    <regex>SCAN_COMPLETED\.+INFECTED|Infected files: [1-9]</regex>
    <description>ClamAV: Scheduled scan completed - infections detected</description>
    <group>clamav_scan,virus_detected,</group>
  </rule>

  <!-- MEDIUM: Scan error -->
  <rule id="100112" level="7">
    <if_sid>100100</if_sid>
    <match>SCAN_ERROR</match>
    <description>ClamAV: Scan error occurred - check file permissions or disk space</description>
    <group>clamav_error,system_error,</group>
  </rule>

  <!-- ======================================================================
       OPERATIONAL RULES
       ====================================================================== -->

  <!-- LOW: ClamAV scan started -->
  <rule id="100120" level="3">
    <if_sid>100100</if_sid>
    <match>scan started</match>
    <description>ClamAV: Antivirus scan initiated</description>
    <group>clamav_scan,</group>
  </rule>

  <!-- LOW: Virus database updated -->
  <rule id="100121" level="3">
    <if_sid>100100</if_sid>
    <match>Database updated</match>
    <description>ClamAV: Virus database updated successfully</description>
    <group>clamav_update,</group>
  </rule>

  <!-- MEDIUM: Virus database update failed -->
  <rule id="100122" level="7">
    <if_sid>100100</if_sid>
    <match>Update failed</match>
    <description>ClamAV: Virus database update FAILED - system may be vulnerable</description>
    <group>clamav_error,clamav_update,</group>
  </rule>

  <!-- HIGH: ClamAV database outdated -->
  <rule id="100123" level="10">
    <if_sid>100100</if_sid>
    <regex>WARNING: Your ClamAV installation is OUTDATED</regex>
    <description>ClamAV: Virus definitions are outdated - immediate update required</description>
    <group>clamav_error,clamav_update,vulnerability,</group>
  </rule>

</group>
