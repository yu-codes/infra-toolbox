# ============================================================
# PostgreSQL 備份環境變數設定
# ============================================================

# ---------- PostgreSQL 連線資訊 ----------
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password_here

# ---------- 備份開關 ----------
ENABLE_FULL_BACKUP=true         # 週全量備份（pg_dumpall）
ENABLE_DAILY_BACKUP=true        # 每日備份（pg_dump）
ENABLE_OFFSITE=true             # 異地備份

# ---------- 備份週期 ----------
FULL_BACKUP_DAY=0               # 週日 (0=週日, 1=週一, ..., 6=週六)
DAILY_BACKUP_HOUR=2             # 每日凌晨 2 點
OFFSITE_BACKUP_DAY=1            # 每月 1 號

# ---------- 本地目錄 ----------
BACKUP_BASE=/opt/pg-backup
FULL_DIR=$BACKUP_BASE/full
DAILY_DIR=$BACKUP_BASE/daily
OFFSITE_DIR=$BACKUP_BASE/offsite
LOG_FILE=$BACKUP_BASE/logs/pg-backup.log

# ---------- 備份設定 ----------
# 備份格式：sql (純文字 SQL) 或 custom (自訂格式，支援平行還原)
BACKUP_FORMAT=sql

# 是否壓縮備份檔案（僅適用於 SQL 格式）
ENABLE_COMPRESSION=true

# 壓縮方式：gzip, bzip2, xz, none（僅適用於 SQL 格式）
COMPRESSION_TYPE=gzip

# 壓縮等級（1-9，9 為最高壓縮率但最慢）
COMPRESSION_LEVEL=6

# 是否啟用加密
ENABLE_ENCRYPTION=false

# 加密方式：openssl-aes256, gpg
ENCRYPTION_METHOD=openssl-aes256

# 加密密碼（建議使用強密碼或金鑰檔案）
# 警告：請妥善保管此密碼，遺失將無法還原備份！
ENCRYPTION_PASSWORD=

# 加密金鑰檔案路徑（選用，優先於密碼）
ENCRYPTION_KEY_FILE=

# GPG 收件者（僅當使用 GPG 加密時）
GPG_RECIPIENT=

# 指定要備份的資料庫（逗號分隔，留空則備份所有非範本資料庫）
# 範例：BACKUP_DATABASES=db1,db2,db3
BACKUP_DATABASES=

# ---------- 異地備份設定 ----------
# 遠端路徑（使用 rsync 格式）
# 範例：user@remote-server:/backup/postgres
# 範例：/mnt/nas/postgres-backup
OFFSITE_REMOTE_PATH=

# ---------- 自動刪舊設定 ----------
# 保留最近 N 週的完整備份
FULL_BACKUP_RETAIN_WEEKS=4

# 保留最近 N 天的每日備份
DAILY_RETAIN_DAYS=7

# 保留最近 N 個月的異地備份
OFFSITE_RETAIN_MONTHS=3

# 保留最近 N 天的日誌檔案
LOG_RETAIN_DAYS=30

# ---------- PostgreSQL 客戶端設定 ----------
# 連線逾時（秒）
export PGCONNECT_TIMEOUT=10

# 語句逾時（秒，0 表示無限制）
export PGSTATEMENT_TIMEOUT=0
