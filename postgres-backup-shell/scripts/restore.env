# ============================================================
# PostgreSQL 還原環境變數設定
# ============================================================
# 注意：此檔案為選用，主要設定會從 backup.env 載入
# 這裡的設定會覆蓋 backup.env 中的對應設定

# ---------- 還原目標 PostgreSQL 設定（選用） ----------
# 如果要還原到不同的 PostgreSQL 實例，可以在這裡設定
# 否則將使用 backup.env 中的設定

# 範例：還原到新的 PostgreSQL 實例
# RESTORE_PG_HOST=192.168.1.100
# RESTORE_PG_PORT=5432
# RESTORE_PG_USER=postgres
# RESTORE_PG_PASSWORD=new_password

# ---------- 還原選項 ----------
# 預設還原模式（可被命令列參數覆蓋）
# DEFAULT_RESTORE_TYPE=full          # full/daily/offsite
# DEFAULT_DROP_DATABASE=false        # 是否在還原前刪除資料庫

# 是否在還原前自動備份目標
# AUTO_BACKUP_BEFORE_RESTORE=false

# 還原完成後是否驗證資料完整性
# VERIFY_AFTER_RESTORE=false

# ---------- 安全選項 ----------
# 是否需要確認才能執行還原（建議保持開啟）
# REQUIRE_CONFIRMATION=true

# 是否允許覆蓋現有資料
# ALLOW_OVERWRITE=true

# ---------- 還原效能設定 ----------
# pg_restore 平行作業數（僅適用於 custom 格式）
# RESTORE_JOBS=4

# ---------- 還原日誌 ----------
# 還原操作的日誌檔案（預設使用備份日誌）
# RESTORE_LOG_FILE=$BACKUP_BASE/logs/pg-restore.log
