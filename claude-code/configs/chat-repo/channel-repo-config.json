      }
    },
    "DISCORD_CHANNEL_ID_2": {
      "name": "#project-frontend",
      "repo": "/repos/project-frontend",
      "branch": "main",
      "allowed_users": ["DISCORD_USER_ID_1"],
      "claude_args": {
        "model": "sonnet",
        "permission_mode": "acceptEdits",
        "max_turns": 30,
        "allowed_tools": ["Read", "Edit", "Bash", "Glob", "Grep", "Write"]
      }
    }
  },
  "defaults": {
    "model": "sonnet",
    "permission_mode": "acceptEdits",
    "max_turns": 20,
